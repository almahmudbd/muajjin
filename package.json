{
  "name": "muajjin",
  "private": true,
  "version": "2.7.0",
  "type": "module",
  "engines": {
    "bun": "1.2.2"
  },
  "scripts": {
    "dev": "vite",
    "dev:github": "vite --mode github",
    "build": "vite build",
    "build:github": "vite build --mode github",
    "build:dev": "vite build --mode development",
    "format": "prettier --write .",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "bunx cap sync",
    "cap:open:android": "bunx cap open android",
    "sync:android": "bunx cap sync android",
    "android:build": "bun run build && bunx cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:github": "bun run build:github && bunx cap sync android && cd android && ./gradlew assembleDebug",
    "android:release": "bun run build && bunx cap sync android && cd android && ./gradlew assembleRelease",
    "android:release:github": "bun run build:github && bunx cap sync android && cd android && ./gradlew assembleRelease",
    "android:bundle": "bun run build && bunx cap sync android && cd android && ./gradlew bundleRelease",
    "reproducible:build": "bash scripts/reproducible-build.sh",
    "reproducible:verify": "bash scripts/verify-reproducible.sh"
  },
